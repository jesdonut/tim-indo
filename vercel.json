{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "translate.html", "use": "@vercel/static" },
    { "src": "postal.html", "use": "@vercel/static" },
    { "src": "spell.html", "use": "@vercel/static" },
    { "src": "compress.html", "use": "@vercel/static" },
    { "src": "station.html", "use": "@vercel/static" },
    { "src": "concat.html", "use": "@vercel/static" },
    { "src": "area.html", "use": "@vercel/static" },
    { "src": "greetings.js", "use": "@vercel/static" },
    { "src": "postal_data.json", "use": "@vercel/static" },
    { "src": "data/generated/stations.json", "use": "@vercel/static" },
    { "src": "data/generated/station-aliases.json", "use": "@vercel/static" },
    { "src": "data/generated/postal-coords.json", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/translate", "dest": "/translate.html" },
    { "src": "/postal", "dest": "/postal.html" },
    { "src": "/spell", "dest": "/spell.html" },
    { "src": "/compress", "dest": "/compress.html" },
    { "src": "/station", "dest": "/station.html" },
    { "src": "/concat", "dest": "/concat.html" },
    { "src": "/area", "dest": "/area.html" },
    { "src": "/greetings.js", "dest": "/greetings.js" },
    { "src": "/postal_data.json", "dest": "/postal_data.json" },
    { "src": "/data/generated/stations.json", "dest": "/data/generated/stations.json" },
    { "src": "/data/generated/station-aliases.json", "dest": "/data/generated/station-aliases.json" },
    { "src": "/data/generated/postal-coords.json", "dest": "/data/generated/postal-coords.json" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
